# Copy this file to .env and fill in your details.

# --- Primary account: sends the actual cold emails ---

# Gmail address you're sending from
GMAIL_USER=your.email@gmail.com

# Gmail App Password (NOT your normal password).
# Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Your display name used as the "From" name
SENDER_NAME=Your Name

# IMPORTANT: enable IMAP on this Gmail account (Settings -> See all settings
# -> Forwarding and POP/IMAP -> Enable IMAP). The app watches the inbox for
# bounce reports after each send: a bounced address is marked invalid and the
# next candidate for that company is emailed automatically.

# Port for the local web app (pick something uncommon, not 3000/5000/8080/etc.)
PORT=47281

# --- Send pacing (applies to ALL scheduling modes: now / fixed / randomized) ---
# Every outgoing email passes through a shared gate: at least 4 minutes
# between sends and at most 5 sends in any 20-minute span, across all jobs,
# plus a little random jitter. This is hard-coded (lib/sendGate.js) because
# it's the whole point of the deliverability guardrails - there is no env
# knob to make it faster.

# --- Deliverability: avoid landing in spam ---

# Max emails to send per day across all jobs. Going over your provider's limit
# (~500/day for a free gmail.com account, 2000 for Workspace) gets you
# temporarily blocked and hurts sender reputation. Jobs that hit the cap pause
# and resume automatically once the count resets. Set to 0 to disable the cap.
DAILY_SEND_LIMIT=450

# Warm-up ramp: the daily cap actually enforced starts at this value and
# roughly DOUBLES each week (20 -> 40 -> 80 -> ...) until it reaches
# DAILY_SEND_LIMIT. WHY: mailbox providers judge senders by history - an
# account that suddenly jumps from a few emails a day to hundreds looks like
# a compromised or purchased spam account and gets throttled/spam-foldered
# even when the content is fine. The ramp starts counting from the first
# email ever sent through this app. Set to 0 to disable the ramp.
WARMUP_START_LIMIT=20

# Sending hours (local time): emails are only handed to Gmail inside this
# window, Monday-Friday. Sends that come due outside it are held - not
# dropped - until the window reopens. WHY: real people email recruiters
# during working hours; a message stamped 2:47 a.m. or sent on a Sunday is a
# classic automation fingerprint for spam filters, and goes unread anyway.
# Set both to empty strings to disable the guard.
SEND_HOURS_START=09:00
SEND_HOURS_END=14:30

# Set to true to also allow sends on Saturday/Sunday (not recommended -
# weekend sends spend sender reputation on emails nobody reads).
SEND_ON_WEEKENDS=false

# NOTE: emails are sent exactly as written - no compliance/unsubscribe footer,
# no postal address, no List-Unsubscribe header. This tool is for personal 1:1
# job applications only, never bulk outreach, so those bulk-mail conventions
# would only make a personal email read as mass marketing.

# Optional Reply-To address, if replies should go somewhere other than GMAIL_USER.
# REPLY_TO=your.email@gmail.com

# --- Optional: bounce watching / automatic fallback tuning ---

# How long after each send to keep watching the inbox for its bounce report
# (ms). Most bounces arrive within a minute or two; default 45 minutes.
# WHY this exists at all: a bounced address must never be emailed again
# (repeat bounces are the strongest spammer signal there is), and a bounce
# means the guess was wrong - so the app marks it invalid for 30 days and
# automatically tries the next guessed address for that company instead.
# BOUNCE_WATCH_MS=2700000

# =============================================================================
# APPLYING CHANGES: how to restart the app after editing this file or the code
# =============================================================================
# The app runs in the background as a macOS LaunchAgent, so edits to .env or
# the code don't take effect until you restart it. Run these two lines in
# Terminal (use your own plist filename in place of com.yourname.*), which
# stops the old version and starts the new one:
#
#   launchctl unload ~/Library/LaunchAgents/com.yourname.coldmailautopilot.plist
#   launchctl load   ~/Library/LaunchAgents/com.yourname.coldmailautopilot.plist
#
# Then check it came back up (a "0" in the second column means a clean start):
#
#   launchctl list | grep coldmail
#
# You do NOT need to restart for anything you do in the web UI (templates,
# recipients, jobs) - only for changes to this file or the .js source.

