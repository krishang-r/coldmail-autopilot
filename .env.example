# Copy this file to .env and fill in your details.

# Gmail address you're sending from
GMAIL_USER=your.email@gmail.com

# Gmail App Password (NOT your normal password).
# Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Your display name used as the "From" name
SENDER_NAME=Your Name

# Port for the local web app (pick something uncommon, not 3000/5000/8080/etc.)
PORT=47281

# Delay in milliseconds between each outgoing email (avoid spam flags / rate
# limits). The actual gap is randomly jittered ±40% around this value so the
# cadence doesn't look robotic.
SEND_DELAY_MS=4000

# --- Deliverability: avoid landing in spam ---

# Max emails to send per day across all jobs. Going over your provider's limit
# (~500/day for a free gmail.com account, 2000 for Workspace) gets you
# temporarily blocked and hurts sender reputation. Jobs that hit the cap pause
# and resume automatically once the count resets. Set to 0 to disable the cap.
DAILY_SEND_LIMIT=450

# Append a CAN-SPAM-style footer (opt-out line + your postal address) to every
# email. Strongly recommended for legitimate cold outreach. Set to false to skip.
APPEND_COMPLIANCE_FOOTER=true

# Physical mailing address shown in the footer (CAN-SPAM requires a real postal
# address in commercial email). Leave blank to omit the address line.
SENDER_ADDRESS=

# Address recipients can use to opt out (also used for the List-Unsubscribe
# header, a strong signal that keeps mail out of spam). Defaults to GMAIL_USER.
# UNSUBSCRIBE_EMAIL=your.email@gmail.com

# Optional Reply-To address, if replies should go somewhere other than GMAIL_USER.
# REPLY_TO=your.email@gmail.com

# --- Optional: "Deep verify mailboxes" (SMTP RCPT TO probing) tuning ---
# All of these have sane defaults; only set them if you need to be more
# conservative on a network that's easily rate-limited/blocklisted.

# Delay in ms between checking each address on the same domain
SMTP_VERIFY_DELAY_MS=400

# Delay in ms between moving on to a different domain
SMTP_VERIFY_DOMAIN_DELAY_MS=1000

# How long to wait for a connection/response before giving up (ms)
SMTP_VERIFY_TIMEOUT_MS=8000

# Hostname to identify as in the SMTP EHLO greeting (defaults to your machine's hostname)
# SMTP_VERIFY_HELO=your-hostname

# Address to use as MAIL FROM during verification (defaults to GMAIL_USER,
# which is recommended - probing from a real, accountable address is less
# likely to be flagged than a forged one)
# SMTP_VERIFY_FROM=your.email@gmail.com
